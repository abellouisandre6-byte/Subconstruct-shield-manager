-- default drone size if no valid drone is found

DroneSizeTable = {}

for i=1, ValidHoldersCount do
    if SummaryHolderInfoTable[ValidHolders[i]].subvehicleinfo.valid == true then
        local positiveDroneSize = SummaryHolderInfoTable[ValidHolders[i]].subvehicleinfo.PositiveSize
        local negativeDroneSize = SummaryHolderInfoTable[ValidHolders[i]].subvehicleinfo.NegativeSize

        local Info = SummaryHolderInfoTable[ValidHolders[i]].subvehicleinfo

        --separating xyz values from vectors
        local positiveDroneSizeX = positiveDroneSize.x
        local positiveDroneSizeY = positiveDroneSize.y
        local negativeDroneSizeX = negativeDroneSize.x
        local negativeDroneSizeY = negativeDroneSize.y

        local height = positiveDroneSizeY - negativeDroneSizeY
        local width = positiveDroneSizeX - negativeDroneSizeX

