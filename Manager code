-- INITIALIZATION
-------------------------------------------------------

if Init == nil then
    Init = false
end

if not Init then

    -------------------------------------------------------
    -- DATA COLLECTION AND ORGANIZATION
    -------------------------------------------------------
-- getting the number of holders from the game API
    HolderCount = I:Component_GetCount(7)

    WeaponCount = I:GetWeaponCount()

    InitHolderInfoTable = {}

    for i=0,HolderCount-1 do
-- get the block info for the holder from the game API
        local holderblockinfo =  I:Component_GetBlockInfo(7, i)

        local selectedVehicleID =  I:Component_GetIntLogic(7, i)

        local holdDistance = I:Component_GetFloatLogic(7, i)

        local holdAzimuth = I:Component_GetFloatLogic_1(7, i, 1)

        local holdElevation = I:Component_GetFloatLogic_1(7, i, 2)

        local SubConstructIdentifier = holderblockinfo.SubConstructIdentifier

        if I:IsTurret(SubConstructIdentifier) == true then

                        local subconstructinfo = I:GetSubConstructInfo(SubConstructIdentifier)
                -- subconstructinfo contains .LocalPosition, .LocalPositionRelativeToCOM, .Forwards, .LocalForwards, .LocalRotation, .CustomName
            local subvehicleinfo = I:GetFriendlyInfoById(selectedVehicleID) -- friendly info by ID
            

            WeaponData = nil
            WeaponIndex = nil

            local ConstructPosition = I:GetConstructPosition()
            local ConstructForward = I:GetConstructForwardVector()
            local ConstructUp = I:GetConstructUpVector()
            local ConstructRight = I:GetConstructRightVector()

            local SubPosition = subconstructinfo.LocalPosition

            local SubGlobalPosition = ConstructPosition
                + (ConstructForward * SubPosition.z)
                + (ConstructUp * SubPosition.y)
                + (ConstructRight * SubPosition.x)
        
            for ii = 0, WeaponCount - 1 do

                local tempWeaponInfo = I:GetWeaponInfo(ii)

                local WeaponPosition = tempWeaponInfo.GlobalPosition

                local Difference = WeaponPosition - SubGlobalPosition

                local Distance =
                    math.sqrt(
                        Difference.x * Difference.x +
                        Difference.y * Difference.y +
                        Difference.z * Difference.z
                    )

                if Distance < 0.5 then

                    WeaponData = tempWeaponInfo
                    WeaponIndex = ii
                    break

                end
            end

            InitHolderInfoTable[i] = {

                blockinfo = holderblockinfo,

                selectedVehicleID =
                    selectedVehicleID,

                holdDistance =
                    holdDistance,

                holdAzimuth =
                    holdAzimuth,

                holdElevation =
                    holdElevation,

                subconstructinfo =
                    subconstructinfo,

                subconstructId =
                    SubConstructIdentifier,

                subvehicleinfo =
                    subvehicleinfo,

                weaponData =
                    WeaponData,

                weaponIndex =
                    WeaponIndex,

                invalid = false
                }
        
        else    
                
            InitHolderInfoTable[i] = {
                invalid = true
            }
        end
        

    end

    -- create a table to hold all valid holders IDs
    ValidHolders = {}

    for i=0, HolderCount-1 do
        if InitHolderInfoTable[i].invalid == false then
            table.insert(ValidHolders, i)
        end
    end

    ValidHoldersCount = #ValidHolders

    -- regroup all holder weaponInfo to get firelanes
    HWIgroup = {}
    for i=1, #ValidHolders do
        table.insert(HWIgroup, InitHolderInfoTable[ValidHolders[i]].weaponIndex)
    end

Init = true

end

