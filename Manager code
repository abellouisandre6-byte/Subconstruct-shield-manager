-- FUNCTIONS
-------------------------------------------------------

function CheckDroneCollision(
    PositionA,
    RadiusA,
    PositionB,
    RadiusB
)

    local RequiredDistance =
        RadiusA + RadiusB


    return DistanceSquared(
        PositionA,
        PositionB
    )
    <
    RequiredDistance * RequiredDistance

end

function FindSafeDronePosition(
    OriginalPosition,
    TargetIndex,
    HolderID,
    OccupiedDronePositions,
    PlaneRight,
    PlaneUp
)

    local Radius =
        GetDroneCollisionRadius(
            HolderID
        )


    local SearchDistance = 
        Radius * 2 + DroneGap


    local SearchOffsets =
    {
        {x= SearchDistance, y=0},
        {x=-SearchDistance, y=0},
        {x=0, y= SearchDistance},
        {x=0, y=-SearchDistance},

        {x= SearchDistance, y= SearchDistance},
        {x=-SearchDistance, y= SearchDistance},
        {x= SearchDistance, y=-SearchDistance},
        {x=-SearchDistance, y=-SearchDistance}
    }


    for i=1,#SearchOffsets do

        local Offset =
            SearchOffsets[i]


        local TestPosition =
            OriginalPosition
            +
            PlaneRight * Offset.x
            +
            PlaneUp * Offset.y


        local Collision = false


        for j=1,#OccupiedDronePositions do

            local Other =
                OccupiedDronePositions[j]


            if CheckDroneCollision(
                TestPosition,
                Radius,
                Other.Position,
                Other.Radius
            )
            then

                Collision = true
                break

            end

        end


        if Collision == false then

            return TestPosition

        end

    end


    return nil

end

function GetDroneCollisionRadius(HolderID)

    local Size =
        DroneSizeTable[HolderID]

    if Size then

        return math.sqrt(
            Size.width * Size.width +
            Size.height * Size.height
        ) / 2

    end

    return 5

end

function DistanceSquared(A, B)

    local dx = A.x - B.x
    local dy = A.y - B.y
    local dz = A.z - B.z

    return dx*dx + dy*dy + dz*dz

end

function SortHolders(Holders, HolderInfo, SortType, SortOrder)

    table.sort(
        Holders,
        function(a,b)

            local ValueA
            local ValueB


            -- SELECT SORT CRITERIA
            if SortType == "size" then

                ValueA =
                    HolderInfo[a].width *
                    HolderInfo[a].height

                ValueB =
                    HolderInfo[b].width *
                    HolderInfo[b].height


            elseif SortType == "name" then

                ValueA =
                    HolderInfo[a].name or ""

                ValueB =
                    HolderInfo[b].name or ""

            end


            -- SELECT SORT DIRECTION
            if SortOrder == "ascending" then

                return ValueA < ValueB

            else

                return ValueA > ValueB

            end

        end
    )

end

function NormalizeVector(Vector)

    local Length =
        math.sqrt(
            Vector.x^2 +
            Vector.y^2 +
            Vector.z^2
        )

    if Length == 0 then
        return Vector3(0,0,0)
    end

    return Vector3(
        Vector.x / Length,
        Vector.y / Length,
        Vector.z / Length
    )

end

function VectorDot(A, B)

    return 
        A.x * B.x +
        A.y * B.y +
        A.z * B.z

end

function VectorCross(A, B)

    return Vector3(
        A.y * B.z - A.z * B.y,
        A.z * B.x - A.x * B.z,
        A.x * B.y - A.y * B.x
    )

end

function RayPlaneIntersection(RayOrigin, RayDirection, PlaneCenter, PlaneNormal)

    local Dot = VectorDot(RayDirection, PlaneNormal)

    if math.abs(Dot) < 0.001 then
        return nil
    end

    local Difference = PlaneCenter - RayOrigin

    local Distance =
        VectorDot(Difference, PlaneNormal)
        /
        Dot

    return RayOrigin + RayDirection * Distance

end

function WorldToPlane(Position, Center, Right, Up)

    local Offset = Position - Center

    return {
        x = VectorDot(Offset, Right),
        y = VectorDot(Offset, Up)
    }

end

function IsInvalidPosition(
    x,
    y,
    width,
    height,
    InvalidPositions
)

    for i=1,#InvalidPositions do

        local Hole =
            InvalidPositions[i]


        if math.abs(x-Hole.x)
            <
            (width+Hole.width)/2

        and

        math.abs(y-Hole.y)
            <
            (height+Hole.height)/2

        then

            return true

        end

    end


    return false

end

function IsOverlapping(x,y,width,height,Placed)

    for i=1,#Placed do

        local Other = Placed[i]

        if math.abs(x-Other.x) <
        (width+Other.width)/2*HorizontalFactor

        and

        math.abs(y-Other.y) <
        (height+Other.height)/2*VerticalFactor

        then
            return true
        end

    end

    return false

end

