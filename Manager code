-------------------------------------------------------
-- TARGET TRACKING
-------------------------------------------------------

TargetInfoTable = {}

TargetCount = I:GetNumberOfTargets(0)
ValidTargets = 0

for i = 0, TargetCount-1 do

    local targetInfo = I:GetTargetInfo(0, i)
    
    
    if targetInfo.valid == true then
        TargetInfoTable[i] = targetInfo
        ValidTargets = ValidTargets + 1
    end

end

TargetGroups = {}

local constructPosition =
    I:GetConstructPosition()


for i=0,TargetCount-1 do

    local Target = TargetInfoTable[i]

    if Target then

        local Direction =
            NormalizeVector(
                Target.Position - constructPosition
            )


        local Added = false


        for g=1,#TargetGroups do

            local Group =
                TargetGroups[g]


            local Dot =
                VectorDot(
                    Direction,
                    Group.Direction
                )


            if Dot > TargetGroupingAngle then

                table.insert(
                    Group.Targets,
                    Target
                )

                Group.Direction =
                    NormalizeVector(
                        Group.Direction + Direction
                    )

                Added = true
                break

            end

        end


        if Added == false then

            table.insert(
                TargetGroups,
                {
                    Direction = Direction,
                    Targets = {Target}
                }
            )

        end

    end

end

for i=1,#TargetGroups do

    local TotalGroupScore = 0

    for j=1,#TargetGroups[i].Targets do

        TotalGroupScore =
            TotalGroupScore
            +
            TargetGroups[i].Targets[j].Score

    end

    TargetGroups[i].Score =
        TotalGroupScore


    -- calculate average position

    local AveragePosition =
        Vector3(0,0,0)


    for j=1,#TargetGroups[i].Targets do

        AveragePosition =
            AveragePosition
            +
            TargetGroups[i].Targets[j].Position

    end


    AveragePosition =
        AveragePosition
        /
        #TargetGroups[i].Targets


    TargetGroups[i].Position =
        AveragePosition

end

-------------------------------------------------------
-- TARGET PRIORITY ASSIGNMENT
-------------------------------------------------------

TotalScore = 0
AssignedHolderTotal = 0
TargetMetaTable = {}
AssignedHolders = {}

for i = 1, #TargetGroups do

    local Group = TargetGroups[i]

    if Group then

        TotalScore =
            TotalScore
            +
            Group.Score

    end

end

if #TargetGroups > 0 then

    for i = 1, #TargetGroups do

        TargetMetaTable[i] = {}

        local Group = TargetGroups[i]

        if Group then

            local targetScore =
                Group.Score

            local numHoldersForTarget =
                math.floor(
                    (targetScore / TotalScore)
                    *
                    ValidHoldersCount
                )


            TargetMetaTable[i].numHoldersAssigned =
                numHoldersForTarget


            AssignedHolderTotal =
                AssignedHolderTotal
                +
                numHoldersForTarget
            

        end

    end

    -- If no holders were assigned by scoring, distribute evenly across all targets
    if AssignedHolderTotal == 0 
    and ValidHoldersCount > 0 
    and #TargetGroups > 0 then

        local holdersPerTarget =
            math.floor(
                ValidHoldersCount / #TargetGroups
            )

        local remainder =
            ValidHoldersCount % #TargetGroups
            
        for i = 1, #TargetGroups do
            local numHoldersForTarget = holdersPerTarget
            if i <= remainder then
                numHoldersForTarget = numHoldersForTarget + 1
            end
            TargetMetaTable[i].numHoldersAssigned = math.max(0,numHoldersForTarget)
            AssignedHolderTotal = AssignedHolderTotal + numHoldersForTarget
        end
    end

    -- if holders remain unassigned, distribute them to the first target
    if AssignedHolderTotal < ValidHoldersCount then
        TargetMetaTable[1].numHoldersAssigned = TargetMetaTable[1].numHoldersAssigned + (ValidHoldersCount - AssignedHolderTotal)
    end

    local HolderCursor = 1

    for i=1,#TargetGroups do

        AssignedHolders[i] = {}

        local Amount =
            TargetMetaTable[i].numHoldersAssigned


        for j=1,Amount do

            if HolderCursor <= ValidHoldersCount then

                table.insert(
                    AssignedHolders[i],
                    ValidHolders[HolderCursor]
                )

                HolderCursor = HolderCursor + 1

            end

        end

    end

end

