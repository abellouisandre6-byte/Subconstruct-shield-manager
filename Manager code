-------------------------------------------------------
-- WALL GENERATION
-------------------------------------------------------
if #TargetGroups > 0 then

    for i=1, #TargetGroups do

        if AssignedHolders[i] then

            SortHolders(
                AssignedHolders[i],
                DroneSizeTable,
                DroneSortType,
                DroneSortOrder
            )

        end

    end

    DroneWallPositionsForTarget = {}

    for i=1, #TargetGroups do
        
        local constructPosition = I:GetConstructPosition()

        local Target = TargetGroups[i]

        if Target then
            local Aim = TargetGroups[i].Position
            
            local DefenseAxis = Aim - constructPosition
                
            -- creating plane perpendicular to DefenseAxis using vectorcross
            local PlaneRight = NormalizeVector(VectorCross(DefenseAxis, Vector3(0,1,0)))
            local PlaneUp = NormalizeVector(VectorCross(DefenseAxis, PlaneRight))

            -- finding furthest holder from the target to calculate the wall position
            FurthestHolderDistance = 0

                for ii=1, ValidHoldersCount do
                    local HolderPosition = SummaryHolderInfoTable[ValidHolders[ii]].subconstructinfo.LocalPosition
                    -- Calculate Global position of holder with local position and construct position
                    -- convert local position to global position
                    local globalHolderPosition = constructPosition + (I:GetConstructForwardVector() * HolderPosition.z) +
                        (I:GetConstructUpVector() * HolderPosition.y) +
                        (I:GetConstructRightVector() * HolderPosition.x)
                    -- Calculate distance from holder to target
                    local temp = globalHolderPosition - Aim
                    local distanceToTarget = math.sqrt(temp.x^2 + temp.y^2 + temp.z^2)

                    if distanceToTarget > FurthestHolderDistance then
                        FurthestHolderDistance = distanceToTarget
                        FurthestHolderPosition = globalHolderPosition
                    end


                end
                
            WallCenter = FurthestHolderPosition + (NormalizeVector(DefenseAxis) * MaxHolderDistance) -- offset wall center X units towards the target

            -------------------------------------------------------
            -- CREATE FIRING HOLES
            -------------------------------------------------------

            InvalidPositions = {}


            for i=1,#FireLanes do

                local Weapon = FireLanes[i]


                local Hit =
                    RayPlaneIntersection(
                        Weapon.GlobalPosition,
                        Weapon.CurrentDirection,
                        WallCenter,
                        NormalizeVector(DefenseAxis)
                        )


                if Hit then

                    local PlanePos =
                        WorldToPlane(
                            Hit,
                            WallCenter,
                            PlaneRight,
                            PlaneUp
                        )


                    table.insert(
                        InvalidPositions,
                        {
                            x = PlanePos.x,
                            y = PlanePos.y,

                            width = FiringlaneSize,
                            height = FiringlaneSize
                        }
                    )

                end

            end

            -------------------------------------------------------
            -- DRONE POSITION GENERATION
            -------------------------------------------------------

            TIKTAKTOE = {}

            local Placed = {}

            local DroneCount =
                math.min(
                    TargetMetaTable[i].numHoldersAssigned,
                    #AssignedHolders[i]
                )

            for DroneIndex=1,DroneCount do

                local HolderID =
                    AssignedHolders[i][DroneIndex]

                local DroneSize =
                {
                    width =
                        DroneSizeTable[HolderID].width,

                    height =
                        DroneSizeTable[HolderID].height
                }

                local BestX = nil
                local BestY = nil

                ------------------------------------------------
                -- GRID SEARCH
                ------------------------------------------------

                local Columns = GridColumns
                local Rows = GridRows

                local SpacingX =
                    DroneSize.width + DroneGap

                local SpacingY =
                    DroneSize.height + DroneGap


                local GridIndex = DroneIndex - 1

                local CenterColumn = math.floor(Columns/2)
                local CenterRow = math.floor(Rows/2)

                local PlacementOrder = {}

                local CenterX = (Columns - 1) / 2
                local CenterY = (Rows - 1) / 2

                for Row = 0, Rows-1 do
                    for Column = 0, Columns-1 do

                        local dx = Column - CenterX
                        local dy = Row - CenterY

                        table.insert(
                            PlacementOrder,
                            {
                                column = Column,
                                row = Row,
                                distance = dx*dx + dy*dy
                            }
                        )

                    end
                end

                table.sort(
                    PlacementOrder,
                    function(a,b)
                        return a.distance < b.distance
                    end
                )


                local Cell = PlacementOrder[DroneIndex]

                local Column = Cell.column
                local Row = Cell.row


                local x =
                    (Column - (Columns-1)/2)
                    * SpacingX


                local y =
                    (Row - (Rows-1)/2)
                    * SpacingY


                if not IsInvalidPosition(
                        x,
                        y,
                        DroneSize.width,
                        DroneSize.height,
                        InvalidPositions
                    )

                and not IsOverlapping(
                    x,
                    y,
                    DroneSize.width,
                    DroneSize.height,
                    Placed
                )

                then

                    BestX = x
                    BestY = y

                else

                    -- fallback if a firing hole blocks the position
                    for Offset=1,DroneCount do

                        local TestX =
                            x + Offset*SpacingX

                        local TestY =
                            y

                        if not IsInvalidPosition(
                                TestX,
                                TestY,
                                DroneSize.width,
                                DroneSize.height,
                                InvalidPositions
                            )

                        and not IsOverlapping(
                            TestX,
                            TestY,
                            DroneSize.width,
                            DroneSize.height,
                            Placed
                        )

                        then

                            BestX = TestX
                            BestY = TestY

                            break

                        end

                    end

                end

                if BestX then

                    local WorldPosition =
                        WallCenter
                        + PlaneRight*BestX
                        + PlaneUp*BestY

                    table.insert(
                        TIKTAKTOE,
                        WorldPosition
                    )


                    table.insert(
                        Placed,
                        {
                            x=BestX,
                            y=BestY,
                            width=DroneSize.width,
                            height=DroneSize.height
                        }
                    )

                else
                end

            end

            table.insert(
                DroneWallPositionsForTarget,
                TIKTAKTOE
            )
        end

    end

    -------------------------------------
    ---MISSILE INTERCEPTION
    -------------------------------------
    NearbyMissiles = {}

    for i=1,#MissileWarnings do

        local Missile = MissileWarnings[i]

        if Missile.Range < MissileInterceptRange and Missile.Range > MissileMinimumInterceptRange then
            table.insert(NearbyMissiles, Missile)
        end

    end

    -- Sort missiles by danger
    table.sort(
        NearbyMissiles,
        function(a,b)
            return a.Range < b.Range
        end
    )

    -------------------------------------
    -- CREATE LIST OF AVAILABLE DRONES
    -------------------------------------

    AvailableInterceptors = {}

    for TargetIndex=1,#TargetGroups do

        if AssignedHolders[TargetIndex] then

            for i=1,#AssignedHolders[TargetIndex] do

                local HolderID =
                    AssignedHolders[TargetIndex][i]


                table.insert(
                    AvailableInterceptors,
                    {
                        HolderID = HolderID,
                        TargetIndex = TargetIndex,
                        WallIndex = i
                    }
                )

            end

        end

    end
        
    -------------------------------------
    -- ASSIGN MISSILES TO DRONES
    -------------------------------------

    DroneReserved = {}
    InterceptorTargets = {}


    while
        #NearbyMissiles > 0
        and
        #DroneReserved < MaxInterceptors
    do


        local Missile =
            table.remove(
                NearbyMissiles,
                1
            )


        local ClosestDrone = nil

        local ClosestDistance = math.huge



        -- search every free drone

        for i=1,#AvailableInterceptors do


            local Drone =
                AvailableInterceptors[i]


            local HolderInfo =
                SummaryHolderInfoTable[
                    Drone.HolderID
                ]


            local DronePosition =
                HolderInfo.subconstructinfo.LocalPosition


            local ConstructPosition =
                I:GetConstructPosition()


            local GlobalDronePosition =
                ConstructPosition
                +
                I:GetConstructForwardVector()
                *
                DronePosition.z
                +
                I:GetConstructUpVector()
                *
                DronePosition.y
                +
                I:GetConstructRightVector()
                *
                DronePosition.x



            local Distance =
                DistanceSquared(
                    GlobalDronePosition,
                    Missile.Position
                )



            if Distance < ClosestDistance then

                ClosestDistance = Distance
                ClosestDrone = i

            end

        end



        -- assign drone

        if ClosestDrone then


            local Drone =
                AvailableInterceptors[
                    ClosestDrone
                ]


            local Collision = false


            local DroneRadius =
                GetDroneCollisionRadius(
                    Drone.HolderID
                )


            for i=1,#DroneReserved do

                local OtherDrone =
                    DroneReserved[i]


                if OtherDrone.InterceptTarget then


                    local OtherRadius =
                        GetDroneCollisionRadius(
                            OtherDrone.HolderID
                        )


                    if CheckDroneCollision(
                        Missile.Position,
                        DroneRadius,
                        OtherDrone.InterceptTarget,
                        OtherRadius
                    )
                    then

                        Collision = true
                        break

                    end

                end

            end



            if Collision == false then


                Drone.InterceptTarget =
                    Missile.Position


                Drone.OriginalMissile =
                    Missile
                
                InterceptorTargets[
                    Drone.HolderID
                ]
                =
                Missile.Position


                table.insert(
                    DroneReserved,
                    Drone
                )


            else

                -- another drone already covers this position
                Missile.AlreadyCovered = true

            end


        else

            break

        end


    end

    -------------------------------------
    -- APPLY MISSILE INTERCEPT POSITIONS
    --------------------------------------
    
    for i=1,#DroneReserved do
        local Drone = DroneReserved[i]
        if Drone.OriginalMissile then
            local missilePos = Drone.InterceptTarget
            local holderID = Drone.HolderID
        end
    end

    ValidInterceptorPositions = {}

    for i=1,#DroneReserved do

        local Drone =
            DroneReserved[i]

        if DroneWallPositionsForTarget[Drone.TargetIndex] then
            DroneWallPositionsForTarget[
                Drone.TargetIndex
            ]
            [
                Drone.WallIndex
            ]
            =
            Drone.InterceptTarget
        end


    end

    -------------------------------------------------------
    -- DRONE AIMING AND ORIENTATION
    -------------------------------------------------------
    for i=1, #TargetGroups do

        local Target = TargetGroups[i]

        if Target then
        
            for ii=1, #AssignedHolders[i] do

                local HolderID =
                    AssignedHolders[i][ii]
                
                local IsInterceptor = false

                for j=1,#DroneReserved do

                    if DroneReserved[j].HolderID == HolderID then

                        IsInterceptor = true
                        break

                    end

                end

                local DronePosition =
                    DroneWallPositionsForTarget[i][ii]
                
                if DronePosition then
                    
                    -- drone forward and drone up need to be created from the weaponinfo of the holder. WeaponInfo.CurrentDirection will give a 3d vector orientation
                    local WeaponIndex =
                        InitHolderInfoTable[HolderID].weaponIndex

                    local WeaponInfo =
                        I:GetWeaponInfo(WeaponIndex)

                    local DroneForward =
                        NormalizeVector(WeaponInfo.CurrentDirection)
                    -- setting the holder position requires the distance from the holder to the plane,
                    -- we orient the holder towards the plane by orientating its weapon via I:AimWeaponInDirection(weaponIndex, x,y,z, weaponSlot)
                    -- we then need to correct the angle of the subvehicle (held by the holder) to be perpendicular to the plane.
                    -- the azimuth and elevation options on the holder (7) are used to correct the angle of the subvehicle to be perpendicular to the plane.
                    -- we still need to convert local to global coordinates.

                    local HolderPosition = SummaryHolderInfoTable[HolderID].subconstructinfo.LocalPosition
                    
                    local GlobalHolderPosition = I:GetConstructPosition() + (I:GetConstructForwardVector() * HolderPosition.z) +
                            (I:GetConstructUpVector() * HolderPosition.y) +
                            (I:GetConstructRightVector() * HolderPosition.x)
                    
                    local temp = DronePosition - GlobalHolderPosition
                    local holdDistance = math.sqrt(temp.x^2 + temp.y^2 + temp.z^2)

                    if holdDistance > 100 then
                        holdDistance = 100
                    end

                    local constructPosition = I:GetConstructPosition()
                    
                    local Aim = TargetGroups[i].Position

                    if IsInterceptor then
                        HoldAzimuth = 0
                        HoldElevation = 0
                    else
                        local DefenseAxis = Aim - DronePosition

                        local DefenseNormal =
                            NormalizeVector(DefenseAxis)

                        local ConstructUp =
                            I:GetConstructUpVector()

                        

                        local CrossDirection =
                            VectorCross(
                                DroneForward,
                                DefenseNormal
                            )

                        HoldAzimuth =
                            math.deg(
                                math.asin(
                                    VectorDot(
                                        ConstructUp,
                                        CrossDirection
                                    )
                                )
                            )


                        local CurrentDirection =
                            NormalizeVector(
                                WeaponInfo.CurrentDirection
                            )
                        
                        

                        local CurrentVertical =
                            math.asin(CurrentDirection.y)


                        local DesiredVertical =
                            math.asin(DefenseNormal.y)


                        HoldElevation =
                            -math.deg(
                                DesiredVertical - CurrentVertical
                            )
                    end

                    I:Component_SetFloatLogic_3(7, HolderID, 0, holdDistance, 1, HoldAzimuth, 2, HoldElevation)

                    local weaponIndex = InitHolderInfoTable[HolderID].weaponIndex
                    local weaponSlot = 0 -- assuming the weapon slot is 0, adjust if necessary

                    local WeaponPos =
                        WeaponInfo.GlobalPosition

                    local AimTarget =
                        DroneWallPositionsForTarget[i][ii]


                    if InterceptorTargets[HolderID] then

                        AimTarget =
                            InterceptorTargets[HolderID]

                    end


                    local AimDir =
                        NormalizeVector(
                            AimTarget - WeaponPos
                        )

                    local x = AimDir.x
                    local y = AimDir.y
                    local z = AimDir.z

                    I:AimWeaponInDirection(weaponIndex, x,y,z, weaponSlot)
                end
                
            end
        end
    end
end

----------------------------------------------
---RETURN HOLDERS TO INIT POSITION IF NO TARGET
----------------------------------------------

if LastDoneOnce ~= TargetCount then
    
    DoneOnce = false

end

if TargetCount == 0 and DoneOnce == false then

    LastDoneOnce = TargetCount

    DoneOnce = true

    for i=0, ValidHoldersCount-1 do

        if InitHolderInfoTable[i].invalid == false then

            local HolderID = i

            local holdDistance = InitHolderInfoTable[i].holdDistance

            local holdAzimuth = InitHolderInfoTable[i].holdAzimuth

            local holdElevation = InitHolderInfoTable[i].holdElevation

            I:Component_SetFloatLogic_3(7, HolderID, 0, holdDistance, 1, holdAzimuth, 2, holdElevation)
        end
    end

end

end
